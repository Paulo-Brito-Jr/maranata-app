# ============================================================
# Maranata App — variáveis de ambiente
# ============================================================
# Os valores reais vivem no vault homemade. Não comitar .env.local.
# Gerar local: vault get "$VAULT_PASSWORD" <CHAVE>
# ============================================================

# ---- Supabase (banco novo Maranata App, F0.2) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=

# ---- Maranata Key (SSO) ----
MARANATA_KEY_URL=https://maranata-key.vercel.app
MARANATA_KEY_APP_ID=maranata-app

# ---- Sessão / cookies ----
SESSION_SECRET=

# ---- Safe2Pay (pagamento + doação recorrente) ----
SAFE2PAY_API_KEY=
SAFE2PAY_TOKEN=
SAFE2PAY_WEBHOOK_SECRET=

# ---- AI Gateway canônico (LiteLLM) ----
AI_BASE_URL=https://ai.britos.app/v1
AI_GATEWAY_API_KEY=

# ---- Skynet (registro de tarefas/eventos) ----
SKYNET_BASE_URL=https://skynet.britos.app
SKYNET_META_TOKEN=

# ---- App ----
NEXT_PUBLIC_APP_URL=https://maranata.app
