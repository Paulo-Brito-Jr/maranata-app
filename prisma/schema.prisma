// =============================================================================
// Maranata App — schema do banco de dados (Supabase Postgres)
// =============================================================================
// Cobre o que o InChurch tinha + módulos próprios (Kids, Loja, Doações
// Safe2Pay recorrentes, Audit log). Tabelas espelham os dados reais
// auditados (38 tabelas com 14.509 registros) e adicionam o que faltava.
//
// IDs em cuid2. RLS via Supabase policies (definidas em migrations).
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ORGANIZACIONAL
// =============================================================================

enum TipoIgreja {
  CONGREGACAO   // uma das 14 unidades locais
  SEDE          // administração central (1 unidade)
  ACAMPAMENTO   // sítio próprio (Acampamento Maranata) — organiza retiros
}

model Igreja {
  id                  String     @id @default(cuid())
  inchurchId          Int?       @unique // ex: 25524 (Tijuca) — pra cross-ref
  nome                String
  apelido             String?
  tipo                TipoIgreja @default(CONGREGACAO)
  endereco            String?
  cidade              String?
  estado              String?
  cep                 String?
  telefone            String?
  email               String?
  ehSede              Boolean  @default(false)
  regionalId          String?
  regional            Regional? @relation(fields: [regionalId], references: [id])
  ativa               Boolean  @default(true)
  criadaEm            DateTime @default(now())
  atualizadaEm        DateTime @updatedAt

  membros             Membro[]
  visitantes          Visitante[]
  usuariosApp         UsuarioApp[]
  eventos             Evento[]
  celulas             Celula[]
  pregacoes           Pregacao[]
  lancamentos         LancamentoFinanceiro[]
  doacoes             Doacao[]
  contas              ContaBancaria[]
  campanhas           Campanha[]
  pushes              PushNotification[]
  kidsCriancas        KidsCrianca[]
  kidsTurmas          KidsTurma[]
  lojaPedidos         LojaPedido[]
  ebdClasses          EbdClasse[]
  doadores            Doador[]
  pagamentosLocais    PagamentoLocal[]
  equipes             Equipe[]
  trilhas             Trilha[]
  planosLeitura       PlanoLeitura[]
  ibmCursos           IbmCurso[]
  ibmTurmas           IbmTurma[]
  categoriasEvento    CategoriaEvento[]
  categoriasPregacao  CategoriaPregacao[]
  seriesPregacao      SeriePregacao[]
  locaisEvento        LocalEvento[]
  banners             Banner[]
  atalhos             Atalho[]
  devocionais         Devocional[]

  @@index([regionalId])
}

model Regional {
  id        String   @id @default(cuid())
  nome      String   @unique
  descricao String?
  criadaEm  DateTime @default(now())
  igrejas   Igreja[]
}

// =============================================================================
// PESSOAS
// =============================================================================

enum PapelSistema {
  SUPER_ADMIN
  PASTOR_DIRETORIA
  ADMIN_IGREJA
  LIDER_CELULA
  SECRETARIA
  FINANCEIRO
  KIDS_RESPONSAVEL
  MEMBRO
}

enum StatusMembro {
  ATIVO
  INATIVO
  TRANSFERIDO
  FALECIDO
  AFASTADO
}

enum EstadoCivil {
  SOLTEIRO
  CASADO
  DIVORCIADO
  VIUVO
  UNIAO_ESTAVEL
}

model Usuario {
  id              String       @id @default(cuid())
  inchurchId      Int?         @unique
  maranataKeySub  String?      @unique // sub do JWT da Maranata Key
  email           String       @unique
  nome            String
  papel           PapelSistema @default(MEMBRO)
  ativo           Boolean      @default(true)
  ultimoLogin     DateTime?
  criadoEm        DateTime     @default(now())
  atualizadoEm    DateTime     @updatedAt

  membro          Membro?
  pushSubscriptions PushSubscription[]
  atendimentos    AtendimentoPastoral[]
  pastorGeralMinisterios PastorGeralMinisterio[]
  pagamentosValidados PagamentoLocal[] @relation("PagamentosValidados")

  @@index([papel])
}

model Membro {
  id              String        @id @default(cuid())
  inchurchId      Int?          @unique
  igrejaId        String
  igreja          Igreja        @relation(fields: [igrejaId], references: [id])
  usuarioId       String?       @unique
  usuario         Usuario?      @relation(fields: [usuarioId], references: [id])
  usuarioAppId    String?       @unique
  usuarioApp      UsuarioApp?   @relation(fields: [usuarioAppId], references: [id])

  nome            String
  fotoUrl         String?
  email           String?
  telefone        String?
  dataNascimento  DateTime?
  cpf             String?       @unique
  rg              String?
  profissao       String?
  estadoCivil     EstadoCivil?
  conjugueId      String?
  conjugue        Membro?       @relation("MembroConjugue", fields: [conjugueId], references: [id])
  conjugueDe      Membro[]      @relation("MembroConjugue")
  paiId           String?
  pai             Membro?       @relation("MembroPai", fields: [paiId], references: [id])
  filhosPai       Membro[]      @relation("MembroPai")
  maeId           String?
  mae             Membro?       @relation("MembroMae", fields: [maeId], references: [id])
  filhosMae       Membro[]      @relation("MembroMae")

  dataBatismo     DateTime?
  dataConversao   DateTime?
  status          StatusMembro  @default(ATIVO)
  observacoes     String?

  endereco        String?
  cidade          String?
  estado          String?
  cep             String?

  optDiretorio    Boolean       @default(false)
  optAniversario  Boolean       @default(true)
  bio             String?

  criadoEm        DateTime      @default(now())
  atualizadoEm    DateTime      @updatedAt

  participacoes   ParticipanteCelula[]
  inscricoes      InscricaoEvento[]
  pedidos         PedidoOracao[]
  testemunhos     Testemunho[]
  doacoesFeitas   Doacao[]
  jornadas        PessoaJornada[]
  responsaveisKids KidsResponsavel[]
  novoConvertido  NovoConvertido?
  equipes         EquipeMembro[]
  liderancas      LiderancaCelula[]
  pregacaoFavoritas PregacaoFavorita[]
  pregacaoProgressos PregacaoProgresso[]
  pregacaoComentarios PregacaoComentario[]
  planoLeituraInscricoes PlanoLeituraInscricao[]
  devocionalReacoes DevocionalReacao[]
  bibliaBookmarks BibliaBookmark[]
  ebdInscricoes EbdInscricao[]
  ibmCursoMatriculas IbmMatriculaCurso[] @relation("IbmCursoMatricula")
  ibmTurmaMatriculas IbmMatricula[] @relation("IbmTurmaMatricula")
  ibmProfessor IbmProfessor?
  atendimentos    AtendimentoPastoral[]
  historico       HistoricoMembro[]
  doadores        Doador[]
  pagamentosLocais PagamentoLocal[]

  @@index([igrejaId])
  @@index([status])
  @@index([nome])
}

model UsuarioApp {
  id            String   @id @default(cuid())
  inchurchId    Int?     @unique
  igrejaId      String?
  igreja        Igreja?  @relation(fields: [igrejaId], references: [id])
  email         String?
  telefone      String?
  nome          String
  fotoUrl       String?
  registradoEm  DateTime @default(now())
  ultimoAcessoEm DateTime?
  pushToken     String?
  ativo         Boolean  @default(true)
  membro        Membro?
  pushSubscriptions PushSubscription[]

  @@index([igrejaId])
}

model Visitante {
  id              String   @id @default(cuid())
  inchurchId      Int?     @unique
  igrejaId        String
  igreja          Igreja   @relation(fields: [igrejaId], references: [id])
  nome            String
  email           String?
  telefone        String?
  dataPrimeiraVisita DateTime?
  comoConheceu    String?
  observacoes     String?
  membroId        String?  // virou membro?
  criadoEm        DateTime @default(now())

  @@index([igrejaId])
}

model NovoConvertido {
  id              String   @id @default(cuid())
  membroId        String   @unique
  membro          Membro   @relation(fields: [membroId], references: [id])
  dataConversao   DateTime
  pastoral        String?  // quem acompanha
  observacoes     String?
  criadoEm        DateTime @default(now())
}

// =============================================================================
// ESTRUTURA MINISTERIAL
// =============================================================================

model GrupoMinisterial {
  id        String   @id @default(cuid())
  inchurchId Int?    @unique
  nome      String
  descricao String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
}

model Equipe {
  id        String         @id @default(cuid())
  inchurchId Int?          @unique
  nome      String
  descricao String?
  igrejaId  String?        // NULL = ministério geral / sede
  igreja    Igreja?        @relation(fields: [igrejaId], references: [id])
  ativa     Boolean        @default(true)
  membros   EquipeMembro[]
  criadaEm  DateTime       @default(now())

  @@index([igrejaId])
}

model EquipeMembro {
  id        String   @id @default(cuid())
  equipeId  String
  equipe    Equipe   @relation(fields: [equipeId], references: [id], onDelete: Cascade)
  membroId  String
  membro    Membro   @relation(fields: [membroId], references: [id])
  papel     String? // ex: "Coordenador", "Voluntário"
  criadoEm  DateTime @default(now())

  @@unique([equipeId, membroId])
}

// =============================================================================
// CÉLULAS
// =============================================================================

enum TipoRede {
  PG    // Pequenos Grupos (células tradicionais)
  EBD   // Escola Bíblica Dominical (importada pra EbdClasse)
}

enum StatusCelula {
  ATIVA
  INATIVA
  EM_MULTIPLICACAO
  MULTIPLICADA
}

model Rede {
  id          String   @id @default(cuid())
  inchurchId  Int?     @unique
  nome        String   @unique
  cor         String?
  supervisor  String?
  igrejaId    String?
  tipo        TipoRede @default(PG)
  totalCelulas Int     @default(0)
  celulas     Celula[]
  criadaEm    DateTime @default(now())

  @@index([tipo])
}

model Celula {
  id              String       @id @default(cuid())
  inchurchId      Int?         @unique
  igrejaId        String
  igreja          Igreja       @relation(fields: [igrejaId], references: [id])
  redeId          String?
  rede            Rede?        @relation(fields: [redeId], references: [id])
  nome            String
  descricao       String?
  endereco        String?
  cidade          String?
  diaSemana       Int?         // 0=domingo
  horario         String?      // "19:30"
  status          StatusCelula @default(ATIVA)
  linkBuscador    String?      // ex: inchur.ch/K58OW
  criadaEm        DateTime     @default(now())

  participantes   ParticipanteCelula[]
  visitantesCelula VisitanteCelula[]
  lideres         LiderancaCelula[]
  materiais       MaterialApoio[]
  relatorios      RelatorioCelula[]

  @@index([igrejaId])
  @@index([status])
}

model LiderancaCelula {
  id        String   @id @default(cuid())
  celulaId  String
  celula    Celula   @relation(fields: [celulaId], references: [id], onDelete: Cascade)
  membroId  String
  membro    Membro   @relation(fields: [membroId], references: [id])
  papel     String   // "Líder", "Auxiliar", "Supervisor", "Anfitrião"
  criadoEm  DateTime @default(now())

  @@unique([celulaId, membroId, papel])
}

model ParticipanteCelula {
  id          String   @id @default(cuid())
  celulaId    String
  celula      Celula   @relation(fields: [celulaId], references: [id], onDelete: Cascade)
  membroId    String
  membro      Membro   @relation(fields: [membroId], references: [id])
  dataEntrada DateTime @default(now())
  dataSaida   DateTime?
  ativo       Boolean  @default(true)

  @@unique([celulaId, membroId])
}

model VisitanteCelula {
  id        String   @id @default(cuid())
  celulaId  String
  celula    Celula   @relation(fields: [celulaId], references: [id])
  nome      String
  telefone  String?
  email     String?
  visitouEm DateTime @default(now())
  observacoes String?

  @@index([celulaId])
}

model MaterialApoio {
  id        String   @id @default(cuid())
  celulaId  String?
  celula    Celula?  @relation(fields: [celulaId], references: [id])
  titulo    String
  descricao String?
  arquivoUrl String?
  publicadoEm DateTime @default(now())
}

model RelatorioCelula {
  id            String   @id @default(cuid())
  celulaId      String
  celula        Celula   @relation(fields: [celulaId], references: [id])
  dataEncontro  DateTime
  presentes     Int      @default(0)
  visitantes    Int      @default(0)
  conversoes    Int      @default(0)
  observacoes   String?
  criadoEm      DateTime @default(now())

  @@index([celulaId, dataEncontro])
}

// =============================================================================
// EVENTOS
// =============================================================================

enum StatusInscricao {
  PENDENTE
  CONFIRMADA
  CANCELADA
  CHECK_IN
}

model CategoriaEvento {
  id        String   @id @default(cuid())
  inchurchId Int?    @unique
  nome      String   @unique
  cor       String?
  icone     String?
  igrejaId  String?  // NULL = categoria global / sede
  igreja    Igreja?  @relation(fields: [igrejaId], references: [id])
  eventos   Evento[]

  @@index([igrejaId])
}

model Evento {
  id              String           @id @default(cuid())
  inchurchId      Int?             @unique
  igrejaId        String           // Igreja organizadora
  igreja          Igreja           @relation(fields: [igrejaId], references: [id])
  categoriaId     String?
  categoria       CategoriaEvento? @relation(fields: [categoriaId], references: [id])
  titulo          String
  slug            String           @unique
  descricao       String?
  capaUrl         String?
  inicio          DateTime
  fim             DateTime?
  local           String?          // texto livre quando não há localEvento
  endereco        String?          // texto livre quando não há localEvento
  localEventoId   String?          // local físico (igreja diferente ou ext. tipo Acampamento)
  localEvento     LocalEvento?     @relation(fields: [localEventoId], references: [id])
  ehGeral         Boolean          @default(false) // evento da Sede pra todos os membros das 15 unidades
  recorrente      Boolean          @default(false)
  recorrenciaJson Json?            // RRULE simplificada
  inscricoesAbertas Boolean        @default(false)
  inscricoesAteEm DateTime?
  publicado       Boolean          @default(true)
  permiteSemLogin Boolean          @default(false)
  criadoEm        DateTime         @default(now())
  atualizadoEm    DateTime         @updatedAt

  lotes           LoteEvento[]
  ingressos       IngressoEvento[]
  inscricoes      InscricaoEvento[]
  perguntas       PerguntaEvento[]

  @@index([igrejaId])
  @@index([inicio])
  @@index([publicado])
  @@index([ehGeral])
  @@index([localEventoId])
}

model LoteEvento {
  id            String           @id @default(cuid())
  eventoId      String
  evento        Evento           @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  nome          String           // ex: "Lote 1 — Antecipado"
  inicio        DateTime
  fim           DateTime
  preco         Decimal          @db.Decimal(10, 2)
  vagas         Int?
  vagasUsadas   Int              @default(0)
  ativo         Boolean          @default(true)
  ingressos     IngressoEvento[]
}

model IngressoEvento {
  id        String      @id @default(cuid())
  eventoId  String
  evento    Evento      @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  loteId    String?
  lote      LoteEvento? @relation(fields: [loteId], references: [id])
  nome      String      // "Inteira", "Meia", "Estudante"
  preco     Decimal     @db.Decimal(10, 2)
  vagas     Int?
  ativo     Boolean     @default(true)
  inscricoes InscricaoEvento[]
}

model PerguntaEvento {
  id          String           @id @default(cuid())
  eventoId    String
  evento      Evento           @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  pergunta    String
  tipo        String           // "texto", "boolean", "select"
  opcoesJson  Json?
  obrigatoria Boolean          @default(false)
  ordem       Int              @default(0)
  respostas   RespostaInscricao[]
}

model InscricaoEvento {
  id              String           @id @default(cuid())
  eventoId        String
  evento          Evento           @relation(fields: [eventoId], references: [id])
  ingressoId      String?
  ingresso        IngressoEvento?  @relation(fields: [ingressoId], references: [id])
  membroId        String?
  membro          Membro?          @relation(fields: [membroId], references: [id])
  nomeAvulso      String?          // quando inscrição sem login
  emailAvulso     String?
  telefoneAvulso  String?
  status          StatusInscricao  @default(PENDENTE)
  qrCode          String           @unique @default(cuid())
  metodoPagamento MetodoPagamento?
  pagamentoId     String?          // ref Safe2Pay (PIX/CARTAO)
  pagamentoLocalId String?         @unique
  pagamentoLocal  PagamentoLocal?  @relation(fields: [pagamentoLocalId], references: [id])
  valorPago       Decimal?         @db.Decimal(10, 2)
  checkInEm       DateTime?
  respostas       RespostaInscricao[]
  criadoEm        DateTime         @default(now())

  @@index([eventoId, status])
  @@index([membroId])
}

model RespostaInscricao {
  id           String          @id @default(cuid())
  inscricaoId  String
  inscricao    InscricaoEvento @relation(fields: [inscricaoId], references: [id], onDelete: Cascade)
  perguntaId   String
  pergunta     PerguntaEvento  @relation(fields: [perguntaId], references: [id])
  resposta     String
}

// =============================================================================
// MÍDIA — Pregações + Banners + Planos de leitura + Downloads + Transmissões
// =============================================================================

model CategoriaPregacao {
  id        String     @id @default(cuid())
  inchurchId Int?      @unique
  nome      String     @unique
  igrejaId  String?    // NULL = global / sede
  igreja    Igreja?    @relation(fields: [igrejaId], references: [id])
  pregacoes Pregacao[]

  @@index([igrejaId])
}

model SeriePregacao {
  id        String     @id @default(cuid())
  inchurchId Int?      @unique
  titulo    String
  descricao String?
  capaUrl   String?
  igrejaId  String?    // NULL = global / sede
  igreja    Igreja?    @relation(fields: [igrejaId], references: [id])
  criadaEm  DateTime   @default(now())
  pregacoes Pregacao[]

  @@index([igrejaId])
}

model Pregacao {
  id            String             @id @default(cuid())
  inchurchId    Int?               @unique
  igrejaId      String?
  igreja        Igreja?            @relation(fields: [igrejaId], references: [id])
  serieId       String?
  serie         SeriePregacao?     @relation(fields: [serieId], references: [id])
  categoriaId   String?
  categoria     CategoriaPregacao? @relation(fields: [categoriaId], references: [id])
  titulo        String
  pregador      String?
  data          DateTime?
  youtubeId     String?
  soundcloudId  String?
  descricao     String?
  capaUrl       String?
  duracaoSeg    Int?
  execucoes     Int                @default(0)
  publicada     Boolean            @default(true)
  criadaEm      DateTime           @default(now())
  produtosLoja  LojaProduto[]
  favoritos     PregacaoFavorita[]
  progressos    PregacaoProgresso[]
  comentarios   PregacaoComentario[]

  @@index([data])
  @@index([igrejaId])
}

model PregacaoFavorita {
  id          String   @id @default(cuid())
  pregacaoId  String
  pregacao    Pregacao @relation(fields: [pregacaoId], references: [id], onDelete: Cascade)
  membroId    String
  membro      Membro   @relation(fields: [membroId], references: [id], onDelete: Cascade)
  criadoEm    DateTime @default(now())

  @@unique([pregacaoId, membroId])
  @@index([membroId])
}

model PregacaoProgresso {
  id            String   @id @default(cuid())
  pregacaoId    String
  pregacao      Pregacao @relation(fields: [pregacaoId], references: [id], onDelete: Cascade)
  membroId      String
  membro        Membro   @relation(fields: [membroId], references: [id], onDelete: Cascade)
  posicaoSeg    Int      @default(0)
  concluido     Boolean  @default(false)
  ultimaVistaEm DateTime @default(now())

  @@unique([pregacaoId, membroId])
  @@index([membroId, ultimaVistaEm])
}

model PregacaoComentario {
  id          String   @id @default(cuid())
  pregacaoId  String
  pregacao    Pregacao @relation(fields: [pregacaoId], references: [id], onDelete: Cascade)
  membroId    String?
  membro      Membro?  @relation(fields: [membroId], references: [id])
  nomeAvulso  String?
  texto       String
  aprovado    Boolean  @default(false)
  criadoEm    DateTime @default(now())

  @@index([pregacaoId, aprovado])
}

model Transmissao {
  id            String   @id @default(cuid())
  inchurchId    Int?     @unique
  titulo        String
  inicio        DateTime
  fim           DateTime?
  streamUrl     String?
  status        String   // "agendada", "ao_vivo", "encerrada"
  visualizacoes Int      @default(0)
  criadaEm      DateTime @default(now())
}

model Banner {
  id          String   @id @default(cuid())
  inchurchId  Int?     @unique
  titulo      String
  subtitulo   String?
  imagemUrl   String?
  linkUrl     String?
  ordem       Int      @default(0)
  inicio      DateTime?
  fim         DateTime?
  ativo       Boolean  @default(true)
  cliques     Int      @default(0)
  igrejaId    String?  // NULL = banner global (Sede/todas)
  igreja      Igreja?  @relation(fields: [igrejaId], references: [id])
  criadoEm    DateTime @default(now())

  @@index([igrejaId])
}

model PlanoLeitura {
  id        String   @id @default(cuid())
  inchurchId Int?    @unique
  titulo    String
  descricao String?
  diasJson  Json?    // estrutura dos dias [{ dia: 1, livro: "joao", capitulos: [1,2] }]
  capaUrl   String?
  publicado Boolean  @default(true)
  igrejaId  String?  // NULL = global / sede
  igreja    Igreja?  @relation(fields: [igrejaId], references: [id])
  criadoEm  DateTime @default(now())
  inscricoes PlanoLeituraInscricao[]

  @@index([igrejaId])
}

model PlanoLeituraInscricao {
  id              String       @id @default(cuid())
  planoId         String
  plano           PlanoLeitura @relation(fields: [planoId], references: [id], onDelete: Cascade)
  membroId        String
  membro          Membro       @relation(fields: [membroId], references: [id], onDelete: Cascade)
  iniciadaEm      DateTime     @default(now())
  diaAtual        Int          @default(1)
  diasConcluidos  Int[]        @default([])
  concluidaEm     DateTime?

  @@unique([planoId, membroId])
}

model Devocional {
  id              String   @id @default(cuid())
  data            DateTime @db.Date
  versiculoRef    String   // "Jo 3.16"
  versiculoTexto  String
  titulo          String
  texto           String   // markdown
  autor           String?
  capaUrl         String?
  publicado       Boolean  @default(true)
  igrejaId        String?  // NULL = devocional geral (Sede/todas)
  igreja          Igreja?  @relation(fields: [igrejaId], references: [id])
  criadoEm        DateTime @default(now())
  reacoes         DevocionalReacao[]

  @@unique([data, igrejaId])
  @@index([igrejaId])
}

model DevocionalReacao {
  id            String     @id @default(cuid())
  devocionalId  String
  devocional    Devocional @relation(fields: [devocionalId], references: [id], onDelete: Cascade)
  membroId      String
  membro        Membro     @relation(fields: [membroId], references: [id], onDelete: Cascade)
  tipo          String     // amem, abencoado, orei
  criadoEm      DateTime   @default(now())

  @@unique([devocionalId, membroId, tipo])
}

model BibliaBookmark {
  id          String   @id @default(cuid())
  membroId    String
  membro      Membro   @relation(fields: [membroId], references: [id], onDelete: Cascade)
  livro       String
  capitulo    Int
  versiculo   Int
  cor         String?
  nota        String?
  criadoEm    DateTime @default(now())

  @@index([membroId, livro, capitulo])
}

model Download {
  id          String   @id @default(cuid())
  inchurchId  Int?     @unique
  titulo      String
  descricao   String?
  arquivoUrl  String
  categoria   String?
  downloads   Int      @default(0)
  criadoEm    DateTime @default(now())
}

model Atalho {
  id        String   @id @default(cuid())
  titulo    String
  linkUrl   String
  icone     String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  igrejaId  String?  // NULL = atalho global (Sede/todas)
  igreja    Igreja?  @relation(fields: [igrejaId], references: [id])

  @@index([igrejaId])
}

// =============================================================================
// COMUNICAÇÃO — Push notifications
// =============================================================================

enum PushAlvo {
  TODOS
  IGREJA
  MEMBROS
  USUARIOS_APP
  CELULA
  CUSTOM
}

model PushNotification {
  id          String   @id @default(cuid())
  igrejaId    String?
  igreja      Igreja?  @relation(fields: [igrejaId], references: [id])
  titulo      String
  corpo       String
  url         String?
  alvo        PushAlvo @default(TODOS)
  filtroJson  Json?
  agendadoPara DateTime?
  enviadoEm   DateTime?
  totalEnviado Int     @default(0)
  totalAbertura Int    @default(0)
  criadoPor   String?
  templateId  String?
  template    PushTemplate? @relation(fields: [templateId], references: [id])
  criadoEm    DateTime @default(now())

  @@index([agendadoPara])
  @@index([enviadoEm])
}

model PushTemplate {
  id           String   @id @default(cuid())
  nome         String   @unique
  titulo       String
  corpo        String
  url          String?
  alvoPadrao   PushAlvo @default(TODOS)
  filtroJson   Json?
  usos         Int      @default(0)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  envios       PushNotification[]
}

model EmailEnvio {
  id          String   @id @default(cuid())
  para        String
  assunto     String
  template    String?
  payloadJson Json?
  status      String   @default("PENDENTE") // PENDENTE, ENVIADO, FALHA
  erroMsg     String?
  enviadoEm   DateTime?
  resendId    String?
  criadoEm    DateTime @default(now())

  @@index([status])
  @@index([para])
}

model PushSubscription {
  id            String   @id @default(cuid())
  usuarioId     String?
  usuario       Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioAppId  String?
  usuarioApp    UsuarioApp? @relation(fields: [usuarioAppId], references: [id], onDelete: Cascade)
  endpoint      String   @unique
  p256dh        String
  authKey       String
  userAgent     String?
  ativa         Boolean  @default(true)
  ultimoEnvio   DateTime?
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  @@index([usuarioId])
  @@index([usuarioAppId])
  @@index([ativa])
}

// =============================================================================
// INTERCESSÃO
// =============================================================================

enum StatusOracao {
  ABERTO
  EM_ORACAO
  RESPONDIDO
  ARQUIVADO
}

model Sentimento {
  id        String   @id @default(cuid())
  inchurchId Int?    @unique
  nome      String   @unique
  emoji     String?
  cor       String?
  pedidos   PedidoOracao[]
}

model PedidoOracao {
  id            String       @id @default(cuid())
  inchurchId    Int?         @unique
  membroId      String?
  membro        Membro?      @relation(fields: [membroId], references: [id])
  nomeAvulso    String?
  pedido        String
  sentimentoId  String?
  sentimento    Sentimento?  @relation(fields: [sentimentoId], references: [id])
  status        StatusOracao @default(ABERTO)
  intercessorId String?
  publico       Boolean      @default(false)
  anonimo       Boolean      @default(false)
  prazoSla      DateTime?
  respostas     RespostaOracao[]
  velas         OracaoVela[]
  criadoEm      DateTime     @default(now())

  @@index([status])
  @@index([intercessorId])
}

model OracaoVela {
  id        String       @id @default(cuid())
  pedidoId  String
  pedido    PedidoOracao @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  membroId  String?
  nomeAvulso String?
  criadoEm  DateTime     @default(now())

  @@unique([pedidoId, membroId])
}

model RespostaOracao {
  id           String       @id @default(cuid())
  pedidoId     String
  pedido       PedidoOracao @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  texto        String
  autorId      String?
  criadoEm     DateTime     @default(now())
}

model Testemunho {
  id          String   @id @default(cuid())
  inchurchId  Int?     @unique
  membroId    String?
  membro      Membro?  @relation(fields: [membroId], references: [id])
  nomeAvulso  String?
  texto       String
  publicado   Boolean  @default(false)  // public_testimony flag
  destaque    Boolean  @default(false)
  curtidas    Int      @default(0)
  criadoEm    DateTime @default(now())

  @@index([publicado])
}

model EscalaIntercessao {
  id          String   @id @default(cuid())
  diaSemana   Int      // 0=domingo
  hora        Int      // 0-23
  intercessorId String
  ativo       Boolean  @default(true)
  criadoEm    DateTime @default(now())

  @@unique([diaSemana, hora, intercessorId])
}

// =============================================================================
// FINANCEIRO + DOAÇÕES (Safe2Pay)
// =============================================================================

enum TipoLancamento {
  ENTRADA
  SAIDA
}

enum StatusLancamento {
  PENDENTE
  CONCILIADO
  CANCELADO
}

enum FormaPagamento {
  DINHEIRO
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  BOLETO
  TRANSFERENCIA
  OFERTA
}

model CategoriaFinanceira {
  id        String           @id @default(cuid())
  nome      String           @unique
  tipo      TipoLancamento
  cor       String?
  lancamentos LancamentoFinanceiro[]
}

model ContaBancaria {
  id            String   @id @default(cuid())
  igrejaId      String?
  igreja        Igreja?  @relation(fields: [igrejaId], references: [id])
  nome          String
  banco         String?
  agencia       String?
  conta         String?
  saldoInicial  Decimal  @db.Decimal(12, 2) @default(0)
  ativa         Boolean  @default(true)
  lancamentos   LancamentoFinanceiro[]
}

model Fornecedor {
  id        String   @id @default(cuid())
  nome      String
  documento String?
  email     String?
  telefone  String?
  lancamentos LancamentoFinanceiro[]
  criadoEm  DateTime @default(now())
}

model LancamentoFinanceiro {
  id              String              @id @default(cuid())
  inchurchId      Int?                @unique
  igrejaId        String
  igreja          Igreja              @relation(fields: [igrejaId], references: [id])
  categoriaId     String?
  categoria       CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])
  contaId         String?
  conta           ContaBancaria?      @relation(fields: [contaId], references: [id])
  fornecedorId    String?
  fornecedor      Fornecedor?         @relation(fields: [fornecedorId], references: [id])
  tipo            TipoLancamento
  status          StatusLancamento    @default(PENDENTE)
  formaPagamento  FormaPagamento?
  valor           Decimal             @db.Decimal(12, 2)
  data            DateTime
  descricao       String?
  comprovanteUrl  String?
  doacaoId        String?             @unique
  doacao          Doacao?             @relation(fields: [doacaoId], references: [id])
  criadoEm        DateTime            @default(now())

  @@index([igrejaId, data])
  @@index([status])
}

model Campanha {
  id          String    @id @default(cuid())
  igrejaId    String?
  igreja      Igreja?   @relation(fields: [igrejaId], references: [id])
  titulo      String
  slug        String    @unique
  descricao   String?
  capaUrl     String?
  meta        Decimal?  @db.Decimal(12, 2)
  arrecadado  Decimal   @db.Decimal(12, 2) @default(0)
  inicio      DateTime?
  fim         DateTime?
  ativa       Boolean   @default(true)
  doacoes     Doacao[]
  criadaEm    DateTime  @default(now())
}

enum StatusDoacao {
  PENDENTE
  PAGA
  FALHOU
  REEMBOLSADA
  CANCELADA
}

enum FrequenciaDoacao {
  AVULSA
  MENSAL
  ANUAL
}

// Doador / Fornecedor importado do InChurch entry_source.
// Mantém dados ricos de contato + bancários históricos pra contexto pastoral.
model Doador {
  id            String   @id @default(cuid())
  inchurchId    Int?     @unique
  igrejaId      String?
  igreja        Igreja?  @relation(fields: [igrejaId], references: [id])
  membroId      String?
  membro        Membro?  @relation(fields: [membroId], references: [id])

  nome          String
  documento     String?  // CPF ou CNPJ
  email         String?
  telefone      String?
  hasWhatsapp   Boolean  @default(false)
  personType    String?  // natural_person / legal_person
  nationality   String?

  // Dados bancários históricos (pra recibos)
  banco         String?
  agencia       String?
  conta         String?
  pixKey        String?

  // Flags InChurch
  isPayer       Boolean  @default(true)
  isSupplier    Boolean  @default(false)

  observacoes   String?

  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  @@index([igrejaId])
  @@index([documento])
}

model Doacao {
  id              String           @id @default(cuid())
  igrejaId        String
  igreja          Igreja           @relation(fields: [igrejaId], references: [id])
  membroId        String?
  membro          Membro?          @relation(fields: [membroId], references: [id])
  campanhaId      String?
  campanha        Campanha?        @relation(fields: [campanhaId], references: [id])
  nomeDoador      String
  emailDoador     String
  telefoneDoador  String?
  documento       String?
  valor           Decimal          @db.Decimal(12, 2)
  frequencia      FrequenciaDoacao @default(AVULSA)
  status          StatusDoacao     @default(PENDENTE)
  formaPagamento  FormaPagamento
  safe2payId      String?          @unique
  safe2payJson    Json?
  pagaEm          DateTime?
  observacoes     String?
  criadaEm        DateTime         @default(now())

  assinaturaId    String?
  assinatura      Safe2PayAssinatura? @relation(fields: [assinaturaId], references: [id])
  lancamento      LancamentoFinanceiro?

  @@index([igrejaId])
  @@index([status])
}

model Safe2PayAssinatura {
  id            String           @id @default(cuid())
  membroId      String?
  email         String
  valor         Decimal          @db.Decimal(12, 2)
  frequencia    FrequenciaDoacao
  diaMes        Int?             // dia do mês
  safe2payId    String?          @unique
  ativa         Boolean          @default(true)
  iniciadaEm    DateTime         @default(now())
  canceladaEm   DateTime?
  doacoes       Doacao[]
}

// =============================================================================
// JORNADAS / TRILHAS
// =============================================================================

enum StatusJornada {
  EM_ANDAMENTO
  CONCLUIDA
  ABANDONADA
}

model Trilha {
  id          String   @id @default(cuid())
  inchurchId  Int?     @unique
  titulo      String
  descricao   String?
  capaUrl     String?
  ordem       Int      @default(0)
  ativa       Boolean  @default(true)
  obrigatoria Boolean  @default(false) // ex: "Boas-vindas"
  igrejaId    String?  // NULL = global / sede
  igreja      Igreja?  @relation(fields: [igrejaId], references: [id])
  etapas      EtapaTrilha[]
  pessoas     PessoaJornada[]
  criadaEm    DateTime @default(now())

  @@index([igrejaId])
}

model EtapaTrilha {
  id        String   @id @default(cuid())
  trilhaId  String
  trilha    Trilha   @relation(fields: [trilhaId], references: [id], onDelete: Cascade)
  titulo    String
  descricao String?
  ordem     Int      @default(0)
  conteudoJson Json?
  progressos EtapaProgresso[]
}

model EtapaProgresso {
  id              String        @id @default(cuid())
  pessoaJornadaId String
  pessoaJornada   PessoaJornada @relation(fields: [pessoaJornadaId], references: [id], onDelete: Cascade)
  etapaId         String
  etapa           EtapaTrilha   @relation(fields: [etapaId], references: [id], onDelete: Cascade)
  concluidaEm     DateTime      @default(now())
  observacao      String?

  @@unique([pessoaJornadaId, etapaId])
}

model PessoaJornada {
  id              String        @id @default(cuid())
  trilhaId        String
  trilha          Trilha        @relation(fields: [trilhaId], references: [id])
  membroId        String
  membro          Membro        @relation(fields: [membroId], references: [id])
  discipuladorId  String?
  status          StatusJornada @default(EM_ANDAMENTO)
  etapaAtualId    String?
  iniciadaEm      DateTime      @default(now())
  concluidaEm     DateTime?
  avaliacoes      AvaliacaoTrilha[]
  progressos      EtapaProgresso[]

  @@unique([trilhaId, membroId])
}

model AvaliacaoTrilha {
  id              String        @id @default(cuid())
  pessoaJornadaId String
  pessoaJornada   PessoaJornada @relation(fields: [pessoaJornadaId], references: [id], onDelete: Cascade)
  nota            Int           // 1-5
  comentario      String?
  criadaEm        DateTime      @default(now())
}

// =============================================================================
// KIDS — Ministério Infantil (substitui R$59,90/mês InChurch Kids)
// =============================================================================

enum FaixaEtariaKids {
  BERCARIO     // 0-2 anos
  MATERNAL     // 3-5
  KIDS_1       // 6-8
  KIDS_2       // 9-11
}

model KidsCrianca {
  id              String          @id @default(cuid())
  igrejaId        String
  igreja          Igreja          @relation(fields: [igrejaId], references: [id])
  nome            String
  dataNascimento  DateTime
  fotoUrl         String?
  faixaEtaria     FaixaEtariaKids
  autorizaImagem  Boolean         @default(false)
  alergias        String?
  restricoesAlim  String?
  necessidadesEsp String?
  observacoes     String?
  autonomiaEntrada Boolean        @default(false) // pode entrar/sair sozinho
  ativa           Boolean         @default(true)
  responsaveis    KidsResponsavel[]
  checkins        KidsCheckin[]
  criadoEm        DateTime        @default(now())
  atualizadoEm    DateTime        @updatedAt

  @@index([igrejaId])
}

model KidsResponsavel {
  id          String      @id @default(cuid())
  criancaId   String
  crianca     KidsCrianca @relation(fields: [criancaId], references: [id], onDelete: Cascade)
  membroId    String?
  membro      Membro?     @relation(fields: [membroId], references: [id])
  nome        String      // nome do responsável (membro ou avulso)
  parentesco  String      // "Mãe", "Pai", "Avó", "Tutor"
  documento   String?
  telefone    String?
  email       String?
  podeBuscar  Boolean     @default(true)
  principal   Boolean     @default(false)
  criadoEm    DateTime    @default(now())

  @@index([criancaId])
}

model KidsTurma {
  id            String           @id @default(cuid())
  igrejaId      String
  igreja        Igreja           @relation(fields: [igrejaId], references: [id])
  nome          String
  faixaEtaria   FaixaEtariaKids
  sala          String?
  capacidade    Int?
  ativa         Boolean          @default(true)
  checkins      KidsCheckin[]
}

model KidsCheckin {
  id            String      @id @default(cuid())
  criancaId     String
  crianca       KidsCrianca @relation(fields: [criancaId], references: [id])
  turmaId       String
  turma         KidsTurma   @relation(fields: [turmaId], references: [id])
  entradaEm     DateTime    @default(now())
  saidaEm       DateTime?
  retiradaPor   String?     // nome de quem buscou
  retiradaDoc   String?
  etiquetaCode  String      @unique @default(cuid())
  observacoes   String?

  @@index([criancaId, entradaEm])
}

// =============================================================================
// LOJA MARANATA (white-label, vs R$259,90/mês InChurch Loja)
// =============================================================================

model LojaCategoria {
  id        String        @id @default(cuid())
  nome      String        @unique
  slug      String        @unique
  ordem     Int           @default(0)
  ativa     Boolean       @default(true)
  produtos  LojaProduto[]
}

enum StatusProduto {
  ATIVO
  RASCUNHO
  ESGOTADO
  DESCONTINUADO
}

model LojaProduto {
  id              String         @id @default(cuid())
  categoriaId     String?
  categoria       LojaCategoria? @relation(fields: [categoriaId], references: [id])
  nome            String
  slug            String         @unique
  descricao       String?
  preco           Decimal        @db.Decimal(10, 2)
  precoPromocional Decimal?      @db.Decimal(10, 2)
  imagensJson     Json?          // [url1, url2...]
  estoque         Int?           // null = sem controle (dropshipping)
  fornecedorExterno String?      // nome do fornecedor catálogo
  status          StatusProduto  @default(RASCUNHO)
  vinculadoPregacaoId String?    // pregação que cita o produto
  pregacao        Pregacao?      @relation(fields: [vinculadoPregacaoId], references: [id], map: "LojaProduto_pregacao_fkey")
  itens           LojaItemPedido[]
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt
}

enum StatusPedido {
  CARRINHO
  AGUARDANDO_PAGAMENTO
  PAGO
  EM_SEPARACAO
  ENVIADO
  ENTREGUE
  CANCELADO
  REEMBOLSADO
}

model LojaPedido {
  id              String       @id @default(cuid())
  igrejaId        String?
  igreja          Igreja?      @relation(fields: [igrejaId], references: [id])
  numero          Int          @unique @default(autoincrement())
  email           String
  nome            String
  telefone        String?
  documento       String?
  enderecoJson    Json?
  status          StatusPedido @default(CARRINHO)
  subtotal        Decimal      @db.Decimal(10, 2) @default(0)
  frete           Decimal      @db.Decimal(10, 2) @default(0)
  desconto        Decimal      @db.Decimal(10, 2) @default(0)
  total           Decimal      @db.Decimal(10, 2) @default(0)
  safe2payId      String?      @unique
  pagoEm          DateTime?
  enviadoEm       DateTime?
  rastreamento    String?
  itens           LojaItemPedido[]
  criadoEm        DateTime     @default(now())
  atualizadoEm    DateTime     @updatedAt
}

model LojaItemPedido {
  id          String       @id @default(cuid())
  pedidoId    String
  pedido      LojaPedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produtoId   String
  produto     LojaProduto  @relation(fields: [produtoId], references: [id])
  quantidade  Int
  precoUnit   Decimal      @db.Decimal(10, 2)
  total       Decimal      @db.Decimal(10, 2)
}

// =============================================================================
// SISTEMA — Audit log + Feature flags + Import log + Referência InChurch
// =============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  usuarioId String?
  acao      String   // "criou", "editou", "deletou", "login"
  recurso   String   // "Membro", "Doacao", etc
  recursoId String?
  diffJson  Json?
  ip        String?
  userAgent String?
  criadoEm  DateTime @default(now())

  @@index([usuarioId])
  @@index([recurso, recursoId])
  @@index([criadoEm])
}

model FeatureFlag {
  id        String   @id @default(cuid())
  chave     String   @unique
  habilitada Boolean @default(false)
  descricao String?
  criadaEm  DateTime @default(now())
  atualizadaEm DateTime @updatedAt
}

model ImportacaoLog {
  id          String   @id @default(cuid())
  fonte       String   // "InChurch", "XLSX", "manual"
  tipo        String   // "membros", "celulas", etc
  totalLinhas Int      @default(0)
  sucesso     Int      @default(0)
  erros       Int      @default(0)
  detalhesJson Json?
  iniciadaEm  DateTime @default(now())
  concluidaEm DateTime?
}

// =============================================================================
// REFERÊNCIA InChurch — congelado pra cross-ref/migração (não escrever ativo)
// =============================================================================

model InChurchSnapshot {
  id          String   @id @default(cuid())
  tipo        String   // "feature_flag", "nomenclatura", "modulo_acesso", "endpoint"
  chave       String
  valorJson   Json
  capturadoEm DateTime @default(now())

  @@unique([tipo, chave])
}

// ============================================================================
// F-P13 — ESCOLA BÍBLICA (EBD + IBM)
// ============================================================================
// EBD = Escola Bíblica Dominical (classes simultâneas no domingo, 1 aluno
// participa de 1 classe por ciclo, sem notas formais)
// IBM = Instituto Bíblico Maranata (seminário com grade curricular,
// disciplinas, professores, presença, faltas, notas, boletim, certificado)

enum FaixaEbd {
  BERCARIO
  CRIANCAS
  PRE_ADOLESCENTES
  ADOLESCENTES
  JOVENS
  ADULTOS
  CASAIS
  LIDERES
  TERCEIRA_IDADE
  GERAL
}

model EbdClasse {
  id                 String         @id @default(cuid())
  igrejaId           String
  igreja             Igreja         @relation(fields: [igrejaId], references: [id])
  nome               String
  descricao          String?
  faixa              FaixaEbd       @default(GERAL)
  professorPrincipal String?
  sala               String?
  capacidade         Int?
  diaSemana          Int            @default(0) // 0=domingo
  horario            String         @default("09:00")
  ciclo              String         // ex: "2026.T2"
  capaUrl            String?
  ativa              Boolean        @default(true)
  inscricoes         EbdInscricao[]
  aulas              EbdAula[]
  criadoEm           DateTime       @default(now())

  @@index([igrejaId, ciclo])
  @@index([ativa])
}

model EbdInscricao {
  id          String        @id @default(cuid())
  classeId    String
  classe      EbdClasse     @relation(fields: [classeId], references: [id], onDelete: Cascade)
  membroId    String
  membro      Membro        @relation(fields: [membroId], references: [id])
  ciclo       String
  status      String        @default("ATIVA") // ATIVA, TRANSFERIDA, SAIU, CONCLUIDA
  observacoes String?
  inscritoEm  DateTime      @default(now())
  presencas   EbdPresenca[]

  @@unique([classeId, membroId, ciclo])
  @@index([membroId])
}

model EbdAula {
  id            String        @id @default(cuid())
  classeId      String
  classe        EbdClasse     @relation(fields: [classeId], references: [id], onDelete: Cascade)
  data          DateTime
  titulo        String
  resumo        String?
  materialUrl   String?
  totalPresentes Int          @default(0)
  presencas     EbdPresenca[]
  criadoEm      DateTime      @default(now())

  @@index([classeId, data])
}

model EbdPresenca {
  id           String       @id @default(cuid())
  aulaId       String
  aula         EbdAula      @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  inscricaoId  String
  inscricao    EbdInscricao @relation(fields: [inscricaoId], references: [id], onDelete: Cascade)
  presente     Boolean
  marcadoPorId String?
  marcadoEm    DateTime     @default(now())
  observacao   String?

  @@unique([aulaId, inscricaoId])
}

// IBM ----------------------------------------------------------------------

enum StatusMatricula {
  MATRICULADO
  TRANCADO
  APROVADO
  REPROVADO
  TRANSFERIDO
  ABANDONOU
}

enum TipoAvaliacao {
  PROVA
  TRABALHO
  SEMINARIO
  PROJETO
  PARTICIPACAO
  OUTRO
}

model IbmCurso {
  id               String              @id @default(cuid())
  nome             String              @unique // "Bacharel em Teologia"
  descricao        String?
  cargaHoraria     Int                 // total em horas
  duracaoSemestres Int                 @default(8)
  capaUrl          String?
  ativo            Boolean             @default(true)
  igrejaId         String?             // NULL = curso corporativo / sede
  igreja           Igreja?             @relation(fields: [igrejaId], references: [id])
  disciplinas      IbmDisciplina[]
  matriculas       IbmMatriculaCurso[]
  criadoEm         DateTime            @default(now())

  @@index([igrejaId])
}

model IbmDisciplina {
  id            String              @id @default(cuid())
  cursoId       String
  curso         IbmCurso            @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  codigo        String              @unique // "TEO101"
  nome          String              // "Introdução à Teologia"
  ementa        String?
  creditos      Int                 @default(2)
  cargaHoraria  Int                 @default(40)
  semestreSugerido Int              @default(1)
  ativa         Boolean             @default(true)
  turmas        IbmTurma[]
  preReqsDessa  IbmPreRequisito[]   @relation("disciplinaQueExige")
  preReqsDela   IbmPreRequisito[]   @relation("disciplinaExigida")

  @@index([cursoId])
}

model IbmPreRequisito {
  disciplinaId    String
  disciplina      IbmDisciplina @relation("disciplinaQueExige", fields: [disciplinaId], references: [id], onDelete: Cascade)
  preRequisitoId  String
  preRequisito    IbmDisciplina @relation("disciplinaExigida", fields: [preRequisitoId], references: [id], onDelete: Cascade)

  @@id([disciplinaId, preRequisitoId])
}

model IbmProfessor {
  id          String     @id @default(cuid())
  membroId    String?    @unique
  membro      Membro?    @relation(fields: [membroId], references: [id])
  nome        String
  titulacao   String?    // "Mestre em Teologia, ESTBA"
  bio         String?
  fotoUrl     String?
  ativo       Boolean    @default(true)
  turmas      IbmTurma[]
  criadoEm    DateTime   @default(now())
}

model IbmTurma {
  id            String         @id @default(cuid())
  disciplinaId  String
  disciplina    IbmDisciplina  @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  professorId   String?
  professor     IbmProfessor?  @relation(fields: [professorId], references: [id])
  igrejaId      String?        // NULL = turma corporativa / sede
  igreja        Igreja?        @relation(fields: [igrejaId], references: [id])
  semestre      String         // "2026.1"
  diaSemana     Int            // 0..6
  horario       String         // "19:30"
  sala          String?
  vagas         Int            @default(40)
  status        String         @default("ABERTA") // ABERTA, FECHADA, EM_ANDAMENTO, ENCERRADA
  matriculas    IbmMatricula[]
  aulas         IbmAula[]
  avaliacoes    IbmAvaliacao[]
  criadoEm      DateTime       @default(now())

  @@index([disciplinaId, semestre])
  @@index([igrejaId])
}

model IbmMatriculaCurso {
  id          String   @id @default(cuid())
  alunoId     String
  aluno       Membro   @relation("IbmCursoMatricula", fields: [alunoId], references: [id])
  cursoId     String
  curso       IbmCurso @relation(fields: [cursoId], references: [id])
  matricula   String   @unique // "IBM2026001"
  iniciadaEm  DateTime @default(now())
  concluidaEm DateTime?
  status      String   @default("ATIVO") // ATIVO, TRANCADO, FORMADO, JUBILADO

  @@unique([alunoId, cursoId])
}

model IbmMatricula {
  id          String          @id @default(cuid())
  turmaId     String
  turma       IbmTurma        @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  alunoId     String
  aluno       Membro          @relation("IbmTurmaMatricula", fields: [alunoId], references: [id])
  status      StatusMatricula @default(MATRICULADO)
  mediaFinal  Decimal?        @db.Decimal(5, 2)
  faltas      Int             @default(0)
  notas       IbmNota[]
  presencas   IbmPresenca[]
  criadaEm    DateTime        @default(now())

  @@unique([turmaId, alunoId])
}

model IbmAula {
  id          String        @id @default(cuid())
  turmaId     String
  turma       IbmTurma      @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  data        DateTime
  conteudo    String?
  observacoes String?
  presencas   IbmPresenca[]
  criadoEm    DateTime      @default(now())

  @@index([turmaId, data])
}

model IbmPresenca {
  id          String       @id @default(cuid())
  aulaId      String
  aula        IbmAula      @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  matriculaId String
  matricula   IbmMatricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)
  presente    Boolean
  justificada Boolean      @default(false)
  observacao  String?

  @@unique([aulaId, matriculaId])
}

model IbmAvaliacao {
  id          String        @id @default(cuid())
  turmaId     String
  turma       IbmTurma      @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  tipo        TipoAvaliacao
  titulo      String
  descricao   String?
  peso        Decimal       @db.Decimal(5, 2) @default(1.0)
  dataEntrega DateTime?
  notaMax     Decimal       @db.Decimal(5, 2) @default(10.0)
  notas       IbmNota[]
  criadaEm    DateTime      @default(now())

  @@index([turmaId])
}

model IbmNota {
  id            String       @id @default(cuid())
  matriculaId   String
  matricula     IbmMatricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)
  avaliacaoId   String
  avaliacao     IbmAvaliacao @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)
  valor         Decimal      @db.Decimal(5, 2)
  observacao    String?
  lancadaEm     DateTime     @default(now())
  lancadaPorId  String?

  @@unique([matriculaId, avaliacaoId])
}

// =============================================================================
// FASE 3h — Atendimento pastoral + Campos custom + Subnomenclatura +
// Mensagens/Páginas + Histórico de membro
// =============================================================================

model AtendimentoPastoral {
  id        String   @id @default(cuid())
  membroId  String
  membro    Membro   @relation(fields: [membroId], references: [id])
  pastorId  String
  pastor    Usuario  @relation(fields: [pastorId], references: [id])
  tipo      String   // visita, ligacao, oracao, aconselhamento, outro
  resumo    String
  detalhes  String?
  proximaAcao String?
  realizadoEm DateTime @default(now())
  criadoEm  DateTime @default(now())

  @@index([membroId, realizadoEm])
  @@index([pastorId])
}

model CampoCustomizado {
  id          String   @id @default(cuid())
  inchurchId  Int?     @unique
  chave       String   @unique
  rotulo      String
  tipo        String   // text, number, date, boolean, select
  opcoesJson  Json?    // array de opções se tipo=select
  obrigatorio Boolean  @default(false)
  entidade    String   // "Membro", "Visitante", "Evento"
  ordem       Int      @default(0)
  ativo       Boolean  @default(true)
  respostas   RespostaCampo[]
  criadoEm    DateTime @default(now())
}

model RespostaCampo {
  id        String   @id @default(cuid())
  campoId   String
  campo     CampoCustomizado @relation(fields: [campoId], references: [id])
  entidadeId String   // ID do membro/visitante/evento
  valor     String
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([campoId, entidadeId])
  @@index([entidadeId])
}

model Subnomenclatura {
  id        String   @id @default(cuid())
  inchurchId Int?    @unique
  chave     String   @unique  // ex: "material_apoio"
  padrao    String   // valor padrão InChurch
  customizado String // valor customizado Maranata
  contexto  String?  // descrição de onde aparece
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model MensagemSistema {
  id        String   @id @default(cuid())
  chave     String   @unique
  titulo    String
  conteudo  String
  ativa     Boolean  @default(true)
  variaveisJson Json?
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model PaginaMultiuso {
  id        String   @id @default(cuid())
  slug      String   @unique
  titulo    String
  conteudo  String   // markdown
  metaJson  Json?
  publicada Boolean  @default(false)
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model HistoricoMembro {
  id        String   @id @default(cuid())
  membroId  String
  membro    Membro   @relation(fields: [membroId], references: [id])
  tipo      String   // mudanca_igreja, mudanca_status, batismo, transferencia, etc
  diffJson  Json
  observacao String?
  registradoPorId String?
  criadoEm  DateTime @default(now())

  @@index([membroId, criadoEm])
}

// =============================================================================
// PAGAMENTO LOCAL (dinheiro recebido numa das 15 unidades)
// =============================================================================

enum MetodoPagamento {
  PIX
  CARTAO
  DINHEIRO_LOCAL
}

enum StatusPagamentoLocal {
  AGUARDANDO        // criado, esperando pagamento físico
  MEMBRO_INFORMOU   // membro marcou "já paguei" no app
  ADMIN_CONFIRMOU   // admin recebeu, esperando double-check do membro
  VALIDADO          // ambos lados confirmaram OU validador unilateral
  CANCELADO         // expirou ou cancelado manualmente
}

model PagamentoLocal {
  id              String   @id @default(cuid())
  origem          String   // "evento" | "doacao" | "loja"
  origemId        String   // ID do recurso (eventoId, doacaoId, lojaPedidoId)
  valor           Decimal  @db.Decimal(10, 2)
  descricao       String?

  // Quem deve pagar
  membroId        String?
  membro          Membro?  @relation(fields: [membroId], references: [id])
  nomePagador     String?  // fallback quando não é membro logado
  emailPagador    String?
  telefonePagador String?

  // Onde deve pagar
  igrejaId        String
  igreja          Igreja   @relation(fields: [igrejaId], references: [id])

  status          StatusPagamentoLocal @default(AGUARDANDO)

  // Side membro
  membroInformouEm    DateTime?
  observacaoMembro    String?

  // Side admin
  adminConfirmouEm    DateTime?
  adminConfirmouPorId String?
  adminConfirmouPor   Usuario? @relation("PagamentosValidados", fields: [adminConfirmouPorId], references: [id])
  observacaoAdmin     String?

  expiraEm        DateTime?
  canceladoEm     DateTime?
  canceladoMotivo String?

  inscricaoEvento InscricaoEvento?

  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@index([igrejaId, status])
  @@index([membroId])
  @@index([origem, origemId])
}

// =============================================================================
// PASTOR GERAL DE MINISTÉRIO
// (pastor responsável por um ministério em todas as 15 unidades)
// =============================================================================

enum MinisterioGeral {
  KIDS
  TEEN
  JOVENS
  CASAIS
  TERCEIRA_IDADE
  LOUVOR
}

model PastorGeralMinisterio {
  id          String          @id @default(cuid())
  usuarioId   String
  usuario     Usuario         @relation(fields: [usuarioId], references: [id])
  ministerio  MinisterioGeral
  ativo       Boolean         @default(true)
  criadoEm    DateTime        @default(now())

  @@unique([usuarioId, ministerio])
  @@index([ministerio])
}

// =============================================================================
// LOCAL FÍSICO de evento (Acampamento Maranata, salões, igreja diferente da
// organizadora). Separado de Igreja pra permitir lugares que não são unidades.
// =============================================================================

enum TipoLocalEvento {
  IGREJA        // uma das 15 unidades (vincula igrejaId)
  ACAMPAMENTO   // Acampamento Maranata (sítio)
  EXTERNO       // salão alugado, parque, hotel
}

model LocalEvento {
  id          String          @id @default(cuid())
  nome        String          @unique // "Acampamento Maranata", "Salão Jubileu"
  tipo        TipoLocalEvento
  igrejaId    String?         // só preenchido quando tipo=IGREJA
  igreja      Igreja?         @relation(fields: [igrejaId], references: [id])
  endereco    String?
  cidade      String?
  estado      String?
  cep         String?
  capacidade  Int?
  descricao   String?
  fotoUrl     String?
  ativo       Boolean         @default(true)
  criadoEm    DateTime        @default(now())

  eventos     Evento[]

  @@index([tipo])
  @@index([igrejaId])
}
